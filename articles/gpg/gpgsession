#!/usr/bin/env python3
'''Create gnupg logs for gpg article'''

import sys
import os
import re
import subprocess
from contextlib import contextmanager
import tempfile
import pexpect
import argparse
import yaml
from io import StringIO

pjoin = os.path.join


@contextmanager
def chdir(d):
    old = os.getcwd()
    os.chdir(d)
    yield
    os.chdir(old)


class Session(pexpect.spawn):
    def __init__(self, env, preproc=None):
        env_ = {'PS1': '\\$ ', 'PS2': '=>'}
        env_.update(env)
        pexpect.spawn.__init__(self,
                               'bash', ['--norc'],
                               encoding='utf-8',
                               timeout=10,
                               env=env_)
        self.preproc = preproc
        self._prompt = u'\\$ $'
        self._logfd = None
        self._pending = ''
        self.waitready()
        self.sendwait('stty cols 9999')

    def log(self, s):
        s = s.replace('\r', '')
        if self.preproc:
            s = self.preproc(s)
        sys.stdout.write(s)
        if self._logfd:
            self._logfd.write(s)

    def process(self):
        self.log(self._pending)
        m = self.match
        i1, i2 = m.span()
        self.log(m.string[0:i1])
        self._pending = m.string[i1:]
        # print(('lpenz', m.string[0:i1], m.string[i1:]))

    def waitready(self, prompt=None):
        prompt = prompt or self._prompt
        try:
            self.expect(prompt)
        except pexpect.TIMEOUT:
            print(self._pending)
            raise
        return self.process()

    @contextmanager
    def logging(self):
        fd = StringIO()
        self._logfd = fd
        yield fd
        self._logfd = None
        fd.close()

    @contextmanager
    def prompt(self, prompt):
        oldprompt = self._prompt
        self._prompt = prompt
        yield
        self._prompt = oldprompt

    def sendwait(self, cmd, prompt=None):
        self.send(cmd + '\r')
        return self.waitready(prompt=prompt)

    def trimprompt(self, string):
        return re.sub(self._prompt, '', string)

    def done(self):
        self.send('exit\r')
        self.expect(pexpect.EOF)
        self.wait()


@contextmanager
def bgprocess(cmd):
    r = subprocess.Popen(cmd,
                         stdout=subprocess.DEVNULL,
                         stderr=subprocess.DEVNULL)
    yield
    r.kill()
    r.wait()


def passfix(s):
    return re.sub('Enter passphrase: *', 'Enter passphrase:\n', s)


def do_main(gpgconf, outputfile):
    data = {}
    with tempfile.TemporaryDirectory() as tmpdir:
        env = {
            'GNUPGHOME': tmpdir,
        }
        # Create gpg.conf
        with open(pjoin(tmpdir, 'gpg.conf'), 'w') as fd:
            with open(gpgconf, 'r') as fd_gpgconf:
                fd.write(fd_gpgconf.read())
            fd.write('pinentry-mode loopback\n')
        # Start sesssion
        p = Session(env=env, preproc=lambda s: s.replace(tmpdir + '/', ''))
        passphrase = 'asdfasdf'
        with bgprocess(['find', '/', '-type', 'f']):
            # Create key:
            with p.logging() as logfd:
                p.sendwait(
                    'gpg --quick-gen-key '
                    '\'Leandro Lisboa Penz <lpenz@lpenz.org>\' '
                    'default sign 0', ': $')
                p.sendwait(passphrase)
                genkey = passfix(logfd.getvalue())
                data['genkey'] = genkey
        # Figure out uuid:
        m_masteruuid = re.search(
            'gpg: key ([0-9A-F]+) marked as ultimately trusted', genkey)
        masteruuid = m_masteruuid.group(1)
        data['masteruuid'] = masteruuid
        re_uuid = re.compile(u'(ssb|sec) +rsa[0-9]+/(?P<uuid>[0-9A-F]+)')
        # Go to editkey prompt:
        with p.logging() as logfd:
            with p.prompt(': $'):
                p.sendwait('gpg --edit-key %s adduid save' % masteruuid)
                p.sendwait('Leandro Lisboa Penz')
                p.sendwait('llpenz@gmail.com')
                p.sendwait('', '\\? $')
                p.sendwait('O')
            with bgprocess(['find', '/', '-type', 'f']):
                p.sendwait(passphrase)
                data['adduid'] = logfd.getvalue()
        with p.logging() as logfd:
            p.sendwait('gpg --edit-key %s uid 1 primary save' % masteruuid)
            data['uidprimary'] = logfd.getvalue()
        with p.logging() as logfd:
            with p.prompt('\\?[ ?0-9()yN/]* $'):
                p.sendwait('gpg --edit-key %s addkey save' % masteruuid)
                p.sendwait('4')
                p.sendwait('')
                p.sendwait('')
                p.sendwait('y')
            p.sendwait('y', ': $')
            p.sendwait(passphrase)
            data['addkey'] = passfix(logfd.getvalue())
        m_uuid = re_uuid.findall(data['addkey'])
        print(m_uuid)
        data['subkeyuuid'] = [u[1] for u in m_uuid if u[0] == 'ssb'][0]
        with p.logging() as logfd:
            p.sendwait('gpg --edit-key %s notation save' % data['subkeyuuid'],
                       ': $')
            p.sendwait('host@lpenz.org=darkstar')
            data['notation1'] = passfix(logfd.getvalue())
        with p.logging() as logfd:
            p.sendwait('gpg --edit-key %s notation save' % data['subkeyuuid'],
                       ': $')
            p.sendwait('service@lpenz.org=github.com')
            data['notation2'] = passfix(logfd.getvalue())
        p.done()
    with open(outputfile, 'w') as fd:
        yaml.dump(data, fd, indent=4)


def main():
    parser = argparse.ArgumentParser(description='Process some integers.')
    parser.add_argument('gpgconf')
    parser.add_argument('outputfile')
    args = parser.parse_args()
    do_main(args.gpgconf, args.outputfile)


if __name__ == '__main__':
    main()
