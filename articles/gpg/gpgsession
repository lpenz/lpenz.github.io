#!/usr/bin/env python3
'''Create gnupg logs for gpg article'''

import sys
import os
import re
import subprocess
from contextlib import contextmanager
import tempfile
import pexpect
import argparse

pjoin = os.path.join


@contextmanager
def chdir(d):
    old = os.getcwd()
    os.chdir(d)
    yield
    os.chdir(old)


class Session(pexpect.spawn):
    def __init__(self, env, preproc=None):
        env_ = {'PS1': '\\$ ', 'PS2': '=>'}
        env_.update(env)
        pexpect.spawn.__init__(self,
                               'bash', ['--norc'],
                               encoding='utf-8',
                               env=env_)
        self.logfd = None
        self.preproc = preproc
        self.prompt = u'\\$ $'
        self.wait_prompt()
        self.runcmd('stty cols 9999', log=False)

    def log_str(self, s):
        sys.stdout.write(s)
        if self.logfd:
            self.logfd.write(s)

    def process(self, log=True):
        m = self.match
        s = m.string.replace('\r', '')
        if self.preproc:
            s = self.preproc(s)
        if log:
            self.log_str(s)
        return s

    def wait_prompt(self, prompt=None, log=True):
        prompt = prompt or self.prompt
        self.expect(prompt)
        return self.process(log=log)

    def runcmd(self, cmd, log=True):
        self.send(cmd + '\r')
        self.wait_prompt(log=log)

    @contextmanager
    def tmp_logfd(self, fd):
        oldfd = self.logfd
        self.logfd = fd
        yield self.logfd
        self.logfd = oldfd

    @contextmanager
    def tmp_logfile(self, filename):
        with open(filename, 'w') as fd:
            with self.tmp_logfd(fd):
                yield fd

    def done(self):
        self.send('exit\r')
        self.expect(pexpect.EOF)
        self.wait()
        if self.logfd:
            self.logfd.write('\n')


def do_main(gpgconf, genkeyfile, keyuuidfile):
    with tempfile.TemporaryDirectory() as tmpdir:
        env = {
            'GNUPGHOME': tmpdir,
        }
        with open(pjoin(tmpdir, 'gpg.conf'), 'w') as fd:
            with open(gpgconf, 'r') as fd_gpgconf:
                fd.write(fd_gpgconf.read())
            fd.write('pinentry-mode loopback\n')
        p = Session(env=env, preproc=lambda s: s.replace(tmpdir + '/', ''))
        with p.tmp_logfile(genkeyfile) as logfd:
            p.log_str('$ ')
            p.send('gpg --quick-gen-key '
                   '\'Leandro Lisboa Penz <lpenz@lpenz.org>\' '
                   'default default 0\r')
            p.wait_prompt(prompt=u': $')
            p.send('asdfasdf\n')
            logfd.write('\n')
            r = subprocess.Popen(['find', '/', '-type', 'f'],
                                 stdout=subprocess.DEVNULL,
                                 stderr=subprocess.DEVNULL)
            creation_info = p.wait_prompt()
            r.kill()
            r.wait()
        # print('creation_info ***************************')
        # print(creation_info)
        with open(keyuuidfile, 'w') as fd:
            m_uuid = re.search(
                u'pub\\s+[^/]+/(?P<uuid>[0-9A-F]+) [0-9-]+ \\[SC\\]',
                creation_info)
            assert m_uuid
            fd.write(m_uuid.group('uuid'))
        # p.runcmd('ls -l /')
        p.done()


def main():
    parser = argparse.ArgumentParser(description='Process some integers.')
    parser.add_argument('gpgconf')
    parser.add_argument('genkeyfile')
    parser.add_argument('keyuuidfile')
    args = parser.parse_args()
    do_main(args.gpgconf, args.genkeyfile, args.keyuuidfile)


if __name__ == '__main__':
    main()
